{
  "name": "advanced-agi-system",
  "version": "1.0.0",
  "description": "Advanced AGI System with Neural Networks, Quantum-inspired Computing, and Multi-agent Intelligence",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "docker:build": "docker build -t advanced-agi-system .",
    "docker:run": "docker run -p 3000:3000 advanced-agi-system",
    "setup:db": "ts-node scripts/setup/setup-database.ts",
    "setup:models": "ts-node scripts/setup/initialize-models.ts",
    "train": "ts-node scripts/training/train-models.ts",
    "benchmark": "ts-node benchmarks/general-intelligence/agi-benchmark-suite.ts"
  },
  "keywords": [
    "agi",
    "artificial-intelligence",
    "neural-networks",
    "quantum-computing",
    "multi-agent-system",
    "code-intelligence",
    "reasoning-engine",
    "machine-learning",
    "deep-learning",
    "typescript",
    "nodejs"
  ],
  "author": "Advanced AGI Team",
  "license": "MIT",
